/**
 * Inicia o worker de orquestração de billing
 */
export function startBillingOrchestratorWorker() {
    console.log('[BillingOrchestrator] 💰 Worker iniciado (Domain: Billing)');

    const worker = new Worker('billing-orchestrator', async (job) => {
        const { eventType, eventId, correlationId, idempotencyKey, payload } = job.data;
        
        const log = createContextLogger(correlationId || eventId, 'billing');
        
        log.info('start', 'Processando evento', {
            eventType,
            eventId,
            sourceDomain: payload?._sourceDomain || 'unknown'
        });

        try {
            // 🛡️ IDEMPOTÊNCIA
            const existingEvent = await EventStore.findOne({ eventId });
            if (existingEvent?.status === 'processed') {
                log.info('idempotent', 'Evento já processado', { eventId });
                return { status: 'already_processed', idempotent: true };
            }

            // 🎯 DISPATCH POR TIPO DE EVENTO
            // Apenas processa eventos relevantes para Billing
            switch (eventType) {
                // Eventos do domínio Clinical (via ACL)
                case 'SESSION_COMPLETED':
                    return await handleSessionCompleted(job.data, log);
                    
                case 'APPOINTMENT_COMPLETED':
                    return await handleAppointmentCompleted(job.data, log);
                
                // Eventos internos do domínio Billing
                case InsuranceEventTypes.INSURANCE_BATCH_CREATED:
                    return await handleBatchCreated(job.data, log);
                    
                case InsuranceEventTypes.INSURANCE_BATCH_SEALED:
                    return await handleBatchSealed(job.data, log);
                    
                case InsuranceEventTypes.INSURANCE_ITEM_APPROVED:
                    return await handleItemApproved(job.data, log);
                    
                case InsuranceEventTypes.INSURANCE_ITEM_REJECTED:
                    return await handleItemRejected(job.data, log);
                    
                case InsuranceEventTypes.INSURANCE_PAYMENT_RECEIVED:
                    return await handlePaymentReceived(job.data, log);
                    
                case InsuranceEventTypes.INSURANCE_BATCH_REPROCESS_REQUESTED:
                    return await handleReprocessRequested(job.data, log);
                    
                default:
                    log.debug('ignored', 'Evento não relevante para Billing', { eventType });
                    return { status: 'ignored', reason: 'not_billing_event' };
            }

        } catch (error) {
            log.error('error', 'Erro no processamento', { 
                error: error.message,
                eventType,
                stack: error.stack
            });
            
            if (job.attemptsMade >= 4) {
                await moveToDLQ(job, error);
            }
            
            throw error;
        }

    }, {
        connection: redisConnection,
        concurrency: 3,
        limiter: {
            max: 10,
            duration: 1000
        }
    });

    worker.on('completed', (job, result) => {
        console.log(`[BillingOrchestrator] Job ${job.id}: ${result?.status || 'completed'}`);
    });

    worker.on('failed', (job, error) => {
        console.error(`[BillingOrchestrator] Job ${job?.id} falhou:`, error.message);
    });

    console.log('[BillingOrchestrator] Worker registrado na fila: billing-orchestrator');
    return worker;
}

