/**
 * Billing Orchestrator Worker
 * 
 * Worker do domínio Billing que:
 * 1. Consome eventos do domínio Clinical (via adapters)
 * 2. Orquestra fluxo de faturamento
 * 3. NUNCA importa modelos do domínio Clinical diretamente
 * 
 * Comunicação apenas via EVENTOS e ADAPTERS.
 */

import { Worker } from 'bullmq';
