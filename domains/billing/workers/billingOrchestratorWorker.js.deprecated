/**
 * Handler: SESSION_COMPLETED
 * 🎯 Usa Adapter para traduzir evento clínico em ação de billing
 */
async function handleSessionCompleted(eventData, log) {
    const { eventId, correlationId, payload } = eventData;
    
    log.info('clinical_event', 'Recebido SESSION_COMPLETED', {
        sessionId: payload.sessionId,
        patientId: payload.patientId
    });
    
    // 🎯 ADAPTER: Traduz evento clínico para comando de billing
    const command = adaptSessionCompleted(eventData);
    
    if (!command) {
        log.info('filtered', 'Sessão não gera faturamento', {
            sessionId: payload.sessionId,
            reason: 'not_insurance_session'
        });
        return { status: 'filtered', reason: 'not_applicable' };
    }
    
    // Processa comando
    const mongoSession = await mongoose.startSession();
    
    try {
        await mongoSession.startTransaction();
        
        // TODO: Implementar lógica de billing
        // Busca valor do convênio (regra de billing, não clínica)
        // const sessionValue = await getConvenioSessionValue(command.data.insuranceProvider);
        
        // if (!sessionValue) {
        //     log.warn('no_value', 'Convênio sem valor cadastrado', {
        //         provider: command.data.insuranceProvider,
        //         sessionId: payload.sessionId
        //     });
        //     // Não falha - apenas não gera item
        //     await mongoSession.abortTransaction();
        //     return { status: 'skipped', reason: 'no_convenio_value' };
        // }
        
        // Busca ou cria guia
        // const guide = await findOrCreateGuideForSession({
        //     patientId: command.data.patientId,
        //     specialty: command.data.specialty,
        //     insuranceProvider: command.data.insuranceProvider
        // });
        
        // Cria item de insurance - PLACEHOLDER
        const sessionValue = 0; // TODO: Implementar
        const guide = null; // TODO: Implementar
        
        log.info('processed', 'Item de billing criado', {
            sessionId: payload.sessionId,
            value: sessionValue,
            guideId: guide?._id
        });
        
        await mongoSession.commitTransaction();
        
        return {
            status: 'processed',
            sessionId: payload.sessionId,
            billingValue: sessionValue
        };
        
    } catch (error) {
        await mongoSession.abortTransaction();
        throw error;
    } finally {
        mongoSession.endSession();
    }
}

/**
 * Handler: APPOINTMENT_COMPLETED
 */
async function handleAppointmentCompleted(eventData, log) {
    const { payload } = eventData;
    
    const command = adaptAppointmentCompleted(eventData);
    
    if (!command) {
        return { status: 'filtered' };
    }
    
    log.info('clinical_event', 'Verificando guia para appointment', {
        appointmentId: payload.appointmentId
    });
    
    // Lógica de verificar/criar guia
    
    return { status: 'processed' };
}

