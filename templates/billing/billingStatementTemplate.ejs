<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Demonstrativo de Faturamento</title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 12px; padding: 20px; }
        h1 { color: #333; font-size: 18px; margin-bottom: 4px; }
        .subtitle { color: #666; font-size: 12px; margin-bottom: 16px; }
        .info { margin-bottom: 16px; }
        .info div { margin-bottom: 4px; }
        table { width: 100%; border-collapse: collapse; margin-top: 12px; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        th { background: #f3f4f6; }
        .totals { margin-top: 16px; font-weight: bold; }
    </style>
</head>
<body>
    <h1>Demonstrativo de Faturamento</h1>
    <div class="subtitle">
        <%= data.clinicName || 'Clínica Fono Inova' %> · <%= data.insuranceName || data.insuranceProvider %>
    </div>

    <div class="info">
        <div><strong>Paciente:</strong> <%= data.patientName %></div>
        <div><strong>Período:</strong> <%= data.periodLabel %></div>
        <div><strong>Guia:</strong> <%= data.guideNumber || '-' %></div>
    </div>

    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Data</th>
                <th>Profissional</th>
                <th>Especialidade</th>
                <th>Valor Bruto</th>
                <th>Valor Líquido</th>
            </tr>
        </thead>
        <tbody>
            <% data.sessions.forEach(function(session, index) { %>
            <tr>
                <td><%= index + 1 %></td>
                <td><%= session.date %></td>
                <td><%= session.professionalName || '-' %></td>
                <td><%= session.specialty || '-' %></td>
                <td><%= session.grossAmount || session.sessionValue || '-' %></td>
                <td><%= session.netAmount || session.sessionValue || '-' %></td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="totals">
        <div>Total de sessões: <%= data.sessions.length %></div>
        <div>Total bruto: <%= data.totalGross %></div>
        <div>Total líquido: <%= data.totalNet %></div>
    </div>
</body>
</html>
