meta {
  name: 2- Check Before
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/v2/patients/debug/{{v2PatientId}}
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const view = res.body?.view;
  if (view) {
    bru.setEnvVar("v2BeforeTotal", view.totalPayments?.toString() || "0");
    console.log("📊 BEFORE - Total Payments:", view.totalPayments);
  }
}

