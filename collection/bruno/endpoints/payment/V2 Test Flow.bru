meta {
  name: V2 Test Flow
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/v2/patients/debug/{{patientId}}
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:pre-request {
  console.log("========================================");
  console.log("  TESTE PAYMENT V2 - DEBUG VIEW");
  console.log("========================================");
  
  const patientId = bru.getEnvVar("patientId");
  if (!patientId) {
    console.error("❌ patientId não encontrado");
  } else {
    console.log("🔍 Verificando projeção do paciente:", patientId);
  }
}

script:post-response {
  const view = res.body?.view;
  if (view) {
    console.log("\n📊 PATIENTS_VIEW:");
    console.log("   Total Payments:", view.totalPayments);
    console.log("   Last Payment:", view.lastPaymentDate);
    console.log("   Balance:", view.financialBalance);
    
    if (view.recentPayments) {
      console.log("\n💰 Recent Payments:");
      view.recentPayments.slice(0, 3).forEach((p, i) => {
        console.log(`   ${i+1}. ${p.date} - R$${p.amount} (${p.method})`);
      });
    }
  }
  
  console.log("\n========================================");
  console.log("  Próximo: Execute 'Create Payment'");
  console.log("  Depois: Execute este novamente");
  console.log("  Esperado: totalPayments aumentar");
  console.log("========================================");
}

docs {
  # V2 Test Flow
  
  Debug da projeção PatientsView para validar eventos.
  
  ## Fluxo de teste
  1. Execute este endpoint (anote totalPayments)
  2. Execute `Create Payment`
  3. Execute este endpoint novamente
  4. Verifique se totalPayments aumentou
  
  ## Se aumentou
  ✅ Evento PAYMENT_RECEIVED funcionando!
  
  ## Se não aumentou
  ❌ Verifique logs: `tail -f /tmp/server.log | grep PaymentRoutes`
}
