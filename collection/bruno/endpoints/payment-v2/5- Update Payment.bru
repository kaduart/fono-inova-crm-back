meta {
  name: 5- Update Payment
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/payments/{{v2PaymentId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "amount": 299.99,
    "description": "V2 Updated"
  }
}

script:post-response {
  if (res.body?.success) {
    console.log("✅ PAYMENT UPDATED");
    console.log("   📡 Event: PAYMENT_UPDATED");
  }
}

docs {
  # Update Payment
  
