meta {
  name: Update Status
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/payments/{{paymentId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "status": "paid"
  }
}

script:post-response {
  if (res.body?.success) {
    console.log("✅ Status atualizado");
    console.log("📡 Evento: PAYMENT_UPDATED");
  }
}

docs {
  # Update Status
  
  Emite: `PAYMENT_UPDATED`
}
