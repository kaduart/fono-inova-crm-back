{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "NODE_OPTIONS='--dns-result-order=ipv4first --max-old-space-size=1024' node -r dotenv/config server.js",
    "dev": "NODE_OPTIONS=--dns-result-order=ipv4first node scripts/start-dev.js",
    "stop": "node scripts/stop-dev.js",
    "restart": "npm stop && npm run dev",
    "worker": "node -r dotenv/config ./workers/followup.worker.js",
    "worker:doctor": "node -r dotenv/config ./workers/doctor.worker.js",
    "cron": "node -r dotenv/config ./workers/followup.cron.js",
    "test": "node tests/complete.js",
    "test:unit": "node tests/complete.js --unit",
    "test:qa": "node tests/complete.js --qa",
    "test:alta": "node tests/complete.js --alta-intencao",
    "test:regra5": "node tests/complete.js --regra5",
    "test:vitest": "vitest run",
    "test:amanda": "vitest run --config vitest.config.amanda.js",
    "test:e2e": "vitest run --config vitest.config.e2e.js",
    "test:e2e:bugfixes": "vitest run --config vitest.config.bugfixes-e2e.js",
    "test:e2e:bugfixes:watch": "vitest --config vitest.config.bugfixes-e2e.js --watch",
    "test:coverage": "vitest run --coverage",
    "billing:validate": "node scripts/validate-billing-v2.js",
    "billing:monitor": "node scripts/monitor-billing-v2.js",
    "billing:rollback": "FORCE_ROLLBACK=true node scripts/rollback-v2-emergency.js",
    "billing:go-live": "node scripts/go-live-v2.js",
    "billing:worker": "node -r dotenv/config domains/billing/workers/billingConsumerWorker.js",
    "test:billing:e2e": "vitest run tests/billing/billing-v2-e2e.test.js",
    "test:billing:integration": "vitest run tests/billing/billing-worker.integration.test.js",
    "test:billing:load": "node tests/billing/load-test.js",
    "test:billing:pre-deploy": "node tests/billing/pre-deploy-check.js",
    "test:billing:full": "npm run test:billing:pre-deploy && npm run test:billing:e2e && npm run test:billing:load 100",
    "billing:status": "node scripts/status-v2.js",
    "test:safety": "vitest run tests/unit/completeWorker.safety.test.js tests/e2e/appointment-edit-sync.e2e.test.js --forceExit",
    "test:all": "vitest run --forceExit",
    "test:pre-deploy": "npm run test:safety && npm run test:billing:pre-deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@bull-board/express": "^6.13.0",
    "@google-analytics/data": "^5.2.0",
    "@google/genai": "^1.44.0",
    "@napi-rs/canvas": "^0.1.95",
    "@sendgrid/mail": "^8.1.5",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.61.0",
    "chalk": "^5.6.2",
    "cloudinary": "^2.9.0",
    "colorize": "^0.1.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "facebook-nodejs-business-sdk": "^24.0.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "fono-inova-web": "file:..",
    "form-data": "^4.0.5",
    "format": "^0.2.2",
    "google-ads-api": "^21.0.1",
    "googleapis": "^159.0.0",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.6.0",
    "mongodb": "^6.8.0",
    "mongoose": "^8.22.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-html-to-image": "^5.0.0",
    "nodemailer": "^7.0.5",
    "openai": "^6.5.0",
    "pdfkit": "^0.17.1",
    "pino": "^10.3.1",
    "puppeteer": "^24.30.0",
    "redis": "^5.8.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^13.0.0",
    "winston": "^3.17.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/socket.io": "^3.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "mongodb-memory-server": "^9.0.0",
    "nodemon": "^3.1.10",
    "supertest": "^6.3.0",
    "vitest": "^4.0.18"
  }
}
