
# ============================================
# FEATURE FLAGS - TRANSIÇÃO 4.0 EVENT-DRIVEN
# ============================================

# CREATE: Criar agendamento
# true = ativa fluxo 4.0
FF_CREATE_V2=false
# 0-100: porcentagem de canary (0 = desligado, 100 = todos)
FF_CREATE_PERCENTAGE=0

# COMPLETE: Finalizar sessão
FF_COMPLETE_V2=false
FF_COMPLETE_PERCENTAGE=0

# CANCEL: Cancelar agendamento  
FF_CANCEL_V2=false
FF_CANCEL_PERCENTAGE=0

# EMERGENCY ROLLBACK
# true = força todos os fluxos para legado imediatamente
FF_EMERGENCY_ROLLBACK=false

# Rollback Guard - Limite de erros
FF_ERROR_THRESHOLD=10        # erros por minuto
FF_ERROR_WINDOW=60           # janela de tempo em segundos
